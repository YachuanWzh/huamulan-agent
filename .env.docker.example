# =============================================================================
# Docker deployment environment variables
# =============================================================================
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# Then start:
#   docker compose up -d
# =============================================================================

# ---- LLM Provider (REQUIRED) ------------------------------------------------
# API key for OpenAI-compatible provider (DeepSeek, OpenAI, etc.)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL for the OpenAI-compatible API endpoint
LLM_BASE_URL=https://api.deepseek.com

# Model identifier (e.g. deepseek-v4-pro, deepseek-chat, gpt-4.1-mini)
LLM_MODEL=deepseek-v4-pro

# Sampling temperature (0.0–2.0)
LLM_TEMPERATURE=0.2

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=langgraph_db
POSTGRES_PORT=5432

# ---- Redis ------------------------------------------------------------------
REDIS_PORT=6379
CACHE_ENABLED=true

# ---- Ports ------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=80

# ---- Checkpoint -------------------------------------------------------------
CHECKPOINT_TTL_SECONDS=604800
CHECKPOINT_PG_CLEANUP_ENABLED=true

# ---- Skill Routing (semantic + rerank require Ollama) -----------------------
SKILL_ROUTING_SEMANTIC_ENABLED=false
SKILL_ROUTING_RERANK_ENABLED=false

# ---- Knowledge RAG (requires Qdrant + Ollama bge-m3) ------------------------
KNOWLEDGE_RAG_ENABLED=false

# ---- OTEL Alert Webhook -----------------------------------------------------
# Change this to a secure random string if you expose the alert webhook
OTEL_ALERT_WEBHOOK_SECRET=change-me
