# ==============================================================================
# Frontend — Vite Environment Variables
# ==============================================================================
# Copy this file to `.env` and adjust for your environment.
#   cp .env.example .env
#
# Variables prefixed with VITE_ are exposed to client-side code at build time.
# ==============================================================================

# ---- Dev Server Proxy Target -------------------------------------------------
# The backend URL that the Vite dev server proxies /api requests to.
# Only used during local development (`npm run dev`).
#
# Required: no (default: http://localhost:8000)
VITE_API_TARGET=http://localhost:8000
