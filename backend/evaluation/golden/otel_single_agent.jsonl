{"id": "otel-sa-001", "category": "otel_single_agent", "difficulty": "easy", "query": "帮我查一下 frontend 服务最近 15 分钟的 Jaeger trace 数据。", "expected_skills": ["otel-query"], "expected_intent": "troubleshoot", "expected_metrics": [], "expected_entities": ["frontend", "jaeger"], "expected_tool_calls": [{"tool": "query_traces", "args_contains": {"service": "frontend", "lookback": "15m"}}], "expected_answer_contains": ["trace", "span", "frontend"], "forbidden_tools": ["query_metrics"]}
