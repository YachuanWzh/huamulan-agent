{"id": "otel-sa-009", "category": "otel_single_agent", "difficulty": "easy", "query": "用 Jaeger 查一下 payment 服务的 trace，只看最近 5 分钟、限制 5 条。", "expected_skills": ["otel-query"], "expected_intent": "troubleshoot", "expected_metrics": [], "expected_entities": ["payment", "jaeger"], "expected_tool_calls": [{"tool": "query_traces", "args_contains": {"service": "payment", "lookback": "5m", "limit": 5}}], "expected_answer_contains": ["payment", "trace"], "forbidden_tools": ["query_metrics"]}
