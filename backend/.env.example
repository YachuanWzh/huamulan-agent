# ==============================================================================
# Personal Assistant — Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
#
# NEVER commit the `.env` file to version control — it is already listed in
# .gitignore, but double-check before staging.
# ==============================================================================

# ---- PostgreSQL — LangGraph Checkpoint & Audit Store --------------------------
# Connection string for the PostgreSQL database that persists LangGraph agent
# state (checkpoints) and audit logs (approval decisions, security events).
#
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=disable
#
# Required: yes
DATABASE_URL=postgresql://user:password@localhost:5432/langgraph_db?sslmode=disable

# ---- LLM Provider ------------------------------------------------------------
# API key for the LLM provider. This field accepts OpenAI-compatible keys
# (OpenAI, DeepSeek, or any provider exposing an OpenAI-compatible API).
#
# Required: yes (for LLM features)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL of the OpenAI-compatible API endpoint. Most providers use their own
# domain (e.g. https://api.deepseek.com, https://api.openai.com/v1). Leave
# empty to use the SDK default (OpenAI).
#
# Required: no (defaults to provider SDK default)
LLM_BASE_URL=https://api.deepseek.com

# Model identifier understood by the LLM provider (e.g. deepseek-v4-pro,
# gpt-4.1-mini, claude-sonnet-4-6).
#
# Required: yes
LLM_MODEL=deepseek-v4-pro

# Sampling temperature (0.0–2.0). Lower values produce more deterministic
# output; higher values increase randomness.
#
# Required: no (default: 0.2)
LLM_TEMPERATURE=0.2

# ---- Redis Cache (optional) -------------------------------------------------
# Optional acceleration layer for read-heavy APIs and long-term memory prompt
# assembly. PostgreSQL remains the source of truth; if Redis is unavailable,
# the backend falls back to direct PostgreSQL/file reads.
#
# REDIS_URL must use the redis:// or rediss:// scheme. Do not use http://.
#
# Required: no (omitting REDIS_URL disables Redis and uses NoopCache)
CACHE_ENABLED=true
REDIS_URL=redis://redis.example.local:6379/0
CACHE_DEFAULT_TTL_SECONDS=10
CACHE_LOG_TTL_SECONDS=5
CACHE_MEMORY_TTL_SECONDS=60

# ---- Redis-first Checkpoints ------------------------------------------------
# When REDIS_URL is configured, LangGraph checkpoints are written to Redis first
# and archived to PostgreSQL asynchronously. If Redis is unavailable, checkpoint
# writes fall back to synchronous PostgreSQL.
#
# CHECKPOINT_TTL_SECONDS applies to Redis checkpoint keys and PostgreSQL
# checkpoint cleanup. CHECKPOINT_SKIP_NODES removes deterministic graph write
# nodes from checkpoint storage; log source=input/loop is LangGraph checkpoint
# source metadata, not a skippable graph node. Keep agent/tools/approval nodes
# persisted.
CHECKPOINT_TTL_SECONDS=604800
CHECKPOINT_PG_CLEANUP_ENABLED=true
CHECKPOINT_PG_CLEANUP_INTERVAL_SECONDS=3600
CHECKPOINT_REDIS_LRU_ENABLED=true
CHECKPOINT_REDIS_MAXMEMORY_POLICY=allkeys-lru
CHECKPOINT_SKIP_NODES=route_skills,compact_context

# ---- Skill Routing Funnel (optional) ----------------------------------------
# Enables the regex -> semantic retrieval -> LLM judge funnel for progressive
# skill loading. Regex routing always works without these services. Semantic
# routing is opt-in so the backend can still run when Ollama/Qdrant are absent.
# When enabled, the backend attempts to warm up skill embeddings during server
# startup; user requests still perform lazy sync as a fallback for newly changed
# skills or failed startup warmup.
#
# Step 2 embeddings use an Ollama embedding service. For a LAN deployment,
# point SKILL_ROUTING_OLLAMA_BASE_URL at the machine serving bge-m3.
#
# SKILL_ROUTING_VECTOR_STORE controls where skill description vectors live:
#   memory = in-process cache, no external vector database
#   qdrant = LAN Qdrant service over HTTP. The backend sends the API key in
#            the `api-key` header, matching Qdrant's HTTP API.
#
# Required: no (default: disabled, memory vector store)
SKILL_ROUTING_SEMANTIC_ENABLED=false
SKILL_ROUTING_EMBEDDING_MODEL=bge-m3
SKILL_ROUTING_OLLAMA_BASE_URL=http://localhost:11434
# Set to qdrant to persist skill embeddings to Qdrant; memory only warms an in-process cache.
SKILL_ROUTING_VECTOR_STORE=memory
# Example LAN service: http://<qdrant-host>:6333
# SKILL_ROUTING_QDRANT_URL=http://<qdrant-host>:6333
# SKILL_ROUTING_QDRANT_API_KEY=replace-with-your-qdrant-api-key
SKILL_ROUTING_QDRANT_COLLECTION=skill_routes
SKILL_ROUTING_SIMILARITY_THRESHOLD=0.72
SKILL_ROUTING_TOP_K=3
# Optional stage 2.5 rerank. Uses the same Ollama base URL as embeddings.
# qllama/bge-reranker-v2-m3 is exposed through Ollama's /api/embed endpoint.
SKILL_ROUTING_RERANK_ENABLED=false
SKILL_ROUTING_RERANK_MODEL=qllama/bge-reranker-v2-m3
SKILL_ROUTING_RERANK_THRESHOLD=0.72
SKILL_ROUTING_RERANK_TOP_K=3
SKILL_ROUTING_LLM_RETRY_COUNT=1
# Optional dedicated model for the third-stage LLM judge. Empty means use LLM_MODEL.
# SKILL_ROUTING_LLM_MODEL=deepseek-v4-flash

# ---- Skills Directory --------------------------------------------------------
# Absolute or relative path to the directory containing skill definitions
# (Markdown + TOML). Defaults to the `skills/` directory shipped with the
# backend package.
#
# Required: no (default: <backend_package>/skills/)
# SKILLS_DIR=

# ---- Assistant Workspace -----------------------------------------------------
# Root directory for the assistant's sandboxed file-system and shell tools.
# File reads/writes and shell commands are confined under this path.
# Defaults to the current working directory when the server starts.
#
# Required: no (default: <cwd>)
# ASSISTANT_WORKSPACE_DIR=

# ---- CORS — Cross-Origin Resource Sharing ------------------------------------
# JSON array of allowed origins for browser requests. The Vite dev server
# runs on port 5173 by default, so it is pre-configured here.
#
# In production, replace with your frontend's actual origin(s).
#
# Required: no (default: ["http://localhost:5173"])
CORS_ORIGINS=["http://localhost:5173"]

# ---- Langfuse Observability (optional) --------------------------------------
# Langfuse is an open-source LLM observability platform. Set these variables
# to enable automatic tracing of LLM calls, tool executions, and agent graph
# steps. Leave blank to disable tracing.
#
# Get your keys at: https://cloud.langfuse.com (or your self-hosted instance)
#
# Required: no (omitting disables Langfuse tracing)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ---- OTEL Demo Telemetry Query Endpoints (optional) --------------------------
# API endpoints for querying the remote OpenTelemetry Demo observability stack.
# These are used by the otel-query Skill (query_traces / query_metrics) and the
# apm.py analysis engine.
#
# OTEL_JAEGER_API_URL — Jaeger REST API for trace queries.
#   Example: http://<your-otel-server>:32801/jaeger/ui/api
#
# OTEL_PROMETHEUS_PROXY_URL — Prometheus API via Grafana datasource proxy.
#   Example: http://<your-otel-server>:32807/api/datasources/proxy/uid/webstore-metrics/api/v1
#
# Required: no (the otel-query Skill requires these to function)
OTEL_JAEGER_API_URL=
OTEL_PROMETHEUS_PROXY_URL=

# ---- Feishu (飞书) Alert Push Notifications (optional) -------------------------
# When FEISHU_WEBHOOK_URL is configured, P0 and P1 OTEL alerts are automatically
# pushed to the Feishu group. P2/P3 alerts are NOT pushed.
#
# Two messages are sent per alert:
#   1. A brief alert notification as soon as the alert is received.
#   2. A full RCA (Root Cause Analysis) result after analysis completes.
#
# Configuration steps:
#   1. In your Feishu group → Settings → Group Bot → Add Bot → Custom Bot
#   2. Copy the Webhook URL and paste it below.
#   3. (Optional) If signature verification is enabled on the bot, copy the
#      secret and set FEISHU_WEBHOOK_SECRET.
#
#   FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx
#   FEISHU_WEBHOOK_SECRET=your_webhook_secret
#
# Required: no (omitting disables Feishu push)
# FEISHU_WEBHOOK_URL=
# FEISHU_WEBHOOK_SECRET=

# ── Feishu (飞书) Stream Mode — bidirectional agent bot via WebSocket ──────
# Stream Mode uses a WebSocket long connection to receive messages from
# Feishu users and route them to the AI agent for processing. No public
# URL or webhook callback endpoint is required — the long connection
# handles everything.
#
# This is the ONLY way to achieve Feishu → Agent communication
# (the webhook mode above is Agent → Feishu push only).
#
# Setup steps:
#   1. Create a Feishu app at https://open.feishu.cn/app
#   2. Enable the "Bot" capability in your app
#   3. Copy App ID and App Secret from "Credentials and Basic Info"
#   4. In "Event Subscriptions", subscribe to im.message.receive_v1
#   5. Set FEISHU_STREAM_ENABLED=true below
#
# Required for bidirectional mode: FEISHU_APP_ID + FEISHU_APP_SECRET
#FEISHU_APP_ID=cli_xxxxxxxxxxxx
#FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#FEISHU_STREAM_ENABLED=false
